{
  "name": "tap-reader",
  "version": "1.0.0",
  "main": "src/main.tsx",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "heic-to": "^1.5.2",
    "heic2any": "^0.0.4",
    "lucide-react": "^1.18.0",
    "multer": "^2.2.0",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "tesseract.js": "^7.0.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.61.1"
  },
  "scripts": {
    "start": "node server/index.mjs",
    "server": "node server/index.mjs",
    "dev": "concurrently \"node server/index.mjs\" \"vite --host 0.0.0.0\"",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
